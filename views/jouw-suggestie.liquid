{% render 'partials/head.liquid' %}

<header class="mobileHeader">
  <h1>Jouw suggestie</h1>
</header>

<main>

<a href="/suggesties" class="terug knop"><img src="../assets/imgs/undo.svg" alt="terug"></a>

<form action="/jouw-suggestie" method="POST" class="form">
    <label for="plant">Welke plant zou jij willen zien in de tuin?</label>
    <input id="plant" name="suggestion" type="text" placeholder="plant..." alt="suggestie textveld">

    <label for="reden">Waarom zou je dit willen zien?</label>
    <input id="reden" name="suggestion_reason" type="text" placeholder="waarom?..." alt="reden textveld">
  
    <input class="button verstuur" type="submit" value="verstuur" alt="verstuurknop">
</form>
  
</main>

{% render 'partials/foot.liquid' %}
