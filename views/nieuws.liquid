{% render 'partials/head.liquid' %}

<header class="mobileHeader">
<h1>nieuws</h1>
    <ul class="filterHeader">
    <li><a class="filterButton" href="/laatste">laatste</a></li>
    <li><a class="filterButton" href="/inbloei">in de bloei</a></li>
    <li><a class="filterButton" href="/nabloei">na de bloei</a></li>
  </ul>
</header>

<main>

<section class="articleList">
  
    {% for news in news %}
      
      <a href="/artikel/{{ news.slug }}">
        <article class="articlePreview-nieuws">
          <img src="https://fdnd-agency.directus.app/assets/{{ news.image }}" height="50" width="75" alt="plant">
          <h4>{{ news.title | truncate: 25 }}</h4>
        </article>
      </a>
      
    {% endfor %}

</section>
  
</main>
<section class="nav">
  <ul class="nav">
    <li class="nav"><a href="/"><img src="assets/imgs/house.svg" width="" alt="">home</a></li>
    <li class="nav"><a href="/veldverkenner"><img src="assets/imgs/map.svg" width="" alt="">veldverkenner</a></li>
    <li class="nav"><a href="/nieuws"><img src="assets/imgs/newspaper.svg" width="" alt="">nieuws</a></li>
    <li class="nav"><a href="/collectie"><img src="assets/imgs/flower.svg" width="" alt="">collectie</a></li>
  </ul>
</section>



{% render 'partials/foot.liquid' %}