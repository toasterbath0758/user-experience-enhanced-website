{% render 'partials/head.liquid' %}

<header class="mobileHeader">
  <h1>home</h1>
</header>



<main>

  <a href="/suggesties" class="suggesties knop"></a>


  <h2>Welkom Gebruiker</h2>
  <section>
  <h3>Bloemenveld collectie</h3>

  <section class="collectionInfoHome">
    <article>
      <p>
        je hebt nog niks gespaard start de veldverkenner om meer te weten te komen over wat er groeit en je collectie
        aan te vullen
      </p>
    </article>
  </section>
  </section>

<section>
  <h3>Veld Nieuws</h3>
<section class="collectionArticles-home">
<section class="articlePreview-home">
{% for news in news limit:3 %}

