    <h4>
        {{ news.title | truncate: 27}}
    </h4>
      <img src="https://fdnd-agency.directus.app/assets/{{ news.image }}" height="" alt="placeholder plant">
      <p>{{ news.body | truncate: 30}}</p>
    </article>
  
{% endfor %}
</section>
</section>
</section>


</main>

<section class="nav">
